# ==============================================================================
# Backend environment variables
# Copy this file to .env and fill in the values before running the app.
# ==============================================================================

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot

# ------------------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# ------------------------------------------------------------------------------
# AI providers (at least one key required)
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ------------------------------------------------------------------------------
# SSO — Google OAuth2
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# SSO — Amazon Cognito
# ------------------------------------------------------------------------------
AMAZON_COGNITO_CLIENT_ID=
AMAZON_COGNITO_CLIENT_SECRET=
AMAZON_COGNITO_ISSUER_URL=

# ------------------------------------------------------------------------------
# SSO — Keycloak OIDC
# ------------------------------------------------------------------------------
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER_URL=

# ------------------------------------------------------------------------------
# File uploads
# ------------------------------------------------------------------------------
MAX_FILE_SIZE_BYTES=10485760
UPLOAD_DIR=./uploads

# ------------------------------------------------------------------------------
# Rate limiting
# ------------------------------------------------------------------------------
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# ==============================================================================
# Frontend environment variables (apps/frontend/.env)
# ==============================================================================
VITE_API_BASE_URL=http://localhost:3000
